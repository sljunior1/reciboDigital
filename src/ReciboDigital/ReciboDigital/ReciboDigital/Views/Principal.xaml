<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReciboDigital.Views.Principal"
             NavigationPage.HasBackButton="False"
             NavigationPage.HasNavigationBar="True">
    <NavigationPage.ToolbarItems>
        <ToolbarItem  Order="Primary" Priority="2" Text="Pesquisar"/>
    </NavigationPage.ToolbarItems>
    <NavigationPage.TitleView>
        <Image x:Name="imgLogo" HorizontalOptions="CenterAndExpand" VerticalOptions="CenterAndExpand" Source="logo.png" WidthRequest="50" HeightRequest="50"/>
    </NavigationPage.TitleView>
    <StackLayout Margin="20" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">


    </StackLayout>
</ContentPage>